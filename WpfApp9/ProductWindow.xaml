<Window x:Class="WpfApp9.ProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp9"
        mc:Ignorable="d"
        Title="Продукты" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>
        <Grid x:Name="AdminPanel" Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="10">
                <TextBlock Text="Поиск: "/>
                <TextBox x:Name="SearchTextBox" TextChanged="SearchTextBox_TextChanged" Width="233"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="10">
                <TextBlock Text="Сортировка: "/>
                <ComboBox x:Name="SortingComboBox" SelectionChanged="SortingComboBox_SelectionChanged"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Margin="10">
                <TextBlock Text="Фильтрация: "/>
                <ComboBox x:Name="FilterComboBox" SelectionChanged="FilterComboBox_SelectionChanged"/>
            </StackPanel>
            
        </Grid>
        <Button x:Name="OrderButton" HorizontalAlignment="Left" Content="Заказы" Click="OrderButton_Click"/>
        <TextBlock x:Name="FullUserName" HorizontalAlignment="Right" Grid.Row="0"/>
        
        <ScrollViewer Grid.Row="1">
            <ItemsControl x:Name="ProductList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="10" Background="{Binding Background}" Tag="{Binding Id}" MouseDown="Border_MouseDown">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Height="80" Width="80">
                                    <Image Source="{Binding Photo}"/>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock FontWeight="SemiBold">
                                        <Run Text="{Binding Category.Name}"/>
                                        <Run Text=" | "/>
                                        <Run Text="{Binding Name}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Description}"/>
                                    <TextBlock Text="{Binding Provider.Name}"/>
                                    <TextBlock Text="{Binding Producer.Name}"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Цена: "/>
                                        <TextBlock Text="{Binding OldPrice, StringFormat=C2}" Foreground="Red" TextDecorations="Strikethrough"/>
                                        <TextBlock Text="{Binding Price, StringFormat=C2}"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Unit.Name}"/>
                                    <TextBlock Text="{Binding AmountInStock}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{Binding Discount}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        <Button x:Name="CreateButton" Grid.Row="2" HorizontalAlignment="Right" Content="Создать" Visibility="Collapsed" Click="CreateButton_Click"/>
        <Button x:Name="ExitButton" Grid.Row="2" HorizontalAlignment="Left" Content="Выйти" Click="ExitButton_Click" Visibility="Visible"/>
    </Grid>
</Window>
